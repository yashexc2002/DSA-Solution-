## 5. Pseudocode

```
function postorder(node):
    if node == NULL:
        return
    
    postorder(node.left)
    postorder(node.right)
    print node.data
```

---

## 6. C++ Implementation (Line-by-line samjho 👇)

```cpp
#include <iostream>
using namespace std;

// Tree node structure
struct Node {
    int data;
    Node* left;
    Node* right;

    Node(int val) {
        data = val;       // node ka value store kar rahe hain
        left = NULL;      // left child initially NULL
        right = NULL;     // right child initially NULL
    }
};

// Postorder function
void postorder(Node* root) {
    if (root == NULL) {
        return;  // agar node nahi hai to wapas chale jao
    }

    postorder(root->left);   // left subtree pe jao
    postorder(root->right);  // right subtree pe jao
    cout << root->data << " "; // last me root print karo
}

int main() {
    // Tree bana rahe hain
    Node* root = new Node(1);
    root->left = new Node(2);
    root->right = new Node(3);

    postorder(root);  // function call

    return 0;
}
```

