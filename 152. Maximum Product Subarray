## 💻 6. C++ Implementation (Line by Line Explanation)

```cpp
class Solution {
public:
    int maxProduct(vector<int>& nums) {
        
        int maxi = nums[0];   // current maximum product
        int mini = nums[0];   // current minimum product
        int ans = nums[0];    // final answer
        
        for(int i = 1; i < nums.size(); i++) {
            
            // agar number negative hai, toh swap karo
            if(nums[i] < 0) {
                swap(maxi, mini);  
                // kyunki negative se max aur min flip ho jata hai
            }
            
            // ya toh new start karo ya previous multiply karo
            maxi = max(nums[i], maxi * nums[i]);  
            // matlab: ya toh sirf current number lo
            // ya previous max ko multiply karo
            
            mini = min(nums[i], mini * nums[i]);  
            // same logic, but minimum track kar rahe
            
            ans = max(ans, maxi);  
            // global maximum update
        }
        
        return ans;  // final result
    }
};
```

