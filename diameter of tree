# 🌳 Full C++ Code: Diameter of Binary Tree

```cpp
#include <iostream>
using namespace std;

// Tree Node structure
struct TreeNode {
    int val;
    TreeNode* left;
    TreeNode* right;

    // constructor
    TreeNode(int x) {
        val = x;
        left = NULL;
        right = NULL;
    }
};

class Solution {
public:
    int diameter = 0; // final answer store karega

    int dfs(TreeNode* root) {
        // agar node NULL hai → height 0
        if (root == NULL)
            return 0;

        // left subtree ki height
        int left = dfs(root->left);

        // right subtree ki height
        int right = dfs(root->right);

        // diameter update (longest path through this node)
        diameter = max(diameter, left + right);

        // current node ki height return karo
        return 1 + max(left, right);
    }

    int diameterOfBinaryTree(TreeNode* root) {
        dfs(root); // DFS start
        return diameter;
    }
};

int main() {
    /*
        Tree banate hain:

               1
              / \
             2   3
            /
           4
    */

    TreeNode* root = new TreeNode(1);
    root->left = new TreeNode(2);
    root->right = new TreeNode(3);
    root->left->left = new TreeNode(4);

    Solution obj;
    int result = obj.diameterOfBinaryTree(root);

    cout << "Diameter of tree: " << result << endl;

    return 0;
}
```

