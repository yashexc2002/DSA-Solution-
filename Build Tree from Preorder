## 6. C++ Implementation

```cpp
class Solution {
public:
    int i = 0;  // pointer to track preorder

    TreeNode* build(vector<int>& preorder, int minVal, int maxVal) {
        // Agar array khatam ho gaya
        if (i >= preorder.size()) return NULL;

        // Agar value allowed range mein nahi hai
        if (preorder[i] < minVal || preorder[i] > maxVal)
            return NULL;

        // Node create karo
        TreeNode* root = new TreeNode(preorder[i]);
        i++;  // next element pe move

        // Left subtree banao (chhoti values)
        root->left = build(preorder, minVal, root->val);

        // Right subtree banao (badi values)
        root->right = build(preorder, root->val, maxVal);

        return root;
    }

    TreeNode* bstFromPreorder(vector<int>& preorder) {
        return build(preorder, INT_MIN, INT_MAX);
    }
};
```

