## 6. C++ Implementation (with line-by-line meaning)

```cpp
#include <iostream>
#include <string>
using namespace std;

void printsub(string str, string subset){

    // Base case: agar string empty ho gayi
    if(str.size() == 0){
        cout << subset << "\n";  // jo subset bana hai print karo
        return;                  // recursion stop
    }

    char ch = str[0];  // first character uthaya

    // Case 1: include character
    // next string + subset me character add
    printsub(str.substr(1), subset + ch);

    // Case 2: exclude character
    // next string but subset same
    printsub(str.substr(1), subset);
}

int main(){
    string str = "abc";   // original string
    string subset = "";   // starting me empty subset

    printsub(str, subset); // function call

    return 0;
}
```

